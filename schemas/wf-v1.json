{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AmalChandru/termtrace/schemas/wf-v1.json",
  "title": "termtrace workflow",
  "type": "object",
  "required": ["version", "steps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Workflow format version",
      "enum": ["1"]
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["command", "stdout", "stderr", "exit_code", "timestamp"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "exit_code": { "type": "integer" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Wall milliseconds from command sent to PTY until next line or session end"
        }
      }
    }
  }
}